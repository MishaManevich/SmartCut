# Copy to macos-signing.env in this folder (macos-signing.env is gitignored).
# Used by ./build-mac-dmg.sh — never commit real values.

# Exact string from: security find-identity -v -p codesigning
# Pick the line that says "Developer ID Application: ..."
MAC_CODESIGN_IDENTITY="Developer ID Application: Your Company Name (XXXXXXXXXX)"

# Keychain profile name created by ./setup-macos-notary.sh (or notarytool store-credentials)
MAC_NOTARY_KEYCHAIN_PROFILE="smartcut-notary"

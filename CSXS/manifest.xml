<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="11.0" ExtensionBundleId="com.smartcutpro.panel"
  ExtensionBundleVersion="1.0.2"
  ExtensionBundleName="SmartCut"
  Publisher="SmartCut"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <ExtensionList>
    <Extension Id="com.smartcutpro.panel" Version="1.0.2" />
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- Premiere Pro 2024+ (v24.0 through v99) -->
      <Host Name="PPRO" Version="[24.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <!-- CEP 11 shipped with CC 2022 and is current through CC 2025+ -->
      <RequiredRuntime Name="CSXS" Version="11.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.smartcutpro.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <ScriptPath>./host/SmartCutHost.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
            <Parameter>--autoplay-policy=no-user-gesture-required</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>SmartCut</Menu>
          <Geometry>
            <Size>
              <Height>640</Height>
              <Width>340</Width>
            </Size>
            <MinSize>
              <Height>400</Height>
              <Width>280</Width>
            </MinSize>
            <MaxSize>
              <Height>1200</Height>
              <Width>600</Width>
            </MaxSize>
          </Geometry>
          <Icons>
            <Icon Type="Normal">./client/icons/icon-light.png</Icon>
            <Icon Type="RollOver">./client/icons/icon-light.png</Icon>
            <Icon Type="DarkNormal">./client/icons/icon-dark.png</Icon>
            <Icon Type="DarkRollOver">./client/icons/icon-dark.png</Icon>
          </Icons>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
